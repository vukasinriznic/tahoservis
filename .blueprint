models:
    User: { name: string, surname: string, email: 'string unique', password: string, phone: 'string nullable', role: 'enum:klijent,serviser,administrator default:klijent', softDeletes: false, timestamps: timestamps }
    Vehicle: { user_id: 'id foreign:users', registration: string, brand: 'string nullable', model: 'string nullable', timestamps: timestamps }
    ServiceRequest: { user_id: 'id foreign:users', vehicle_id: 'id foreign:vehicles', serviser_id: 'id foreign:users nullable', tachograph_type: 'enum:analogni,digitalni', description: 'text nullable', desired_date: datetime, phone: string, status: 'enum:zakazano,u_dijagnostici,u_popravci,zavrseno default:zakazano', timestamps: timestamps }
    Diagnostic: { service_request_id: 'id foreign:service_requests', problem_description: text, diagnostic_results: text, recommended_work: 'text nullable', timestamps: timestamps }
    Repair: { service_request_id: 'id foreign:service_requests', work_done: text, seal_number: 'string nullable', pdf_path: 'string nullable', timestamps: timestamps }
    Part: { name: string, code: 'string unique', supplier: 'string nullable', quantity: 'integer default:0', timestamps: timestamps }
    RepairPart: { repair_id: 'id foreign:repairs', part_id: 'id foreign:parts', quantity_used: integer }
